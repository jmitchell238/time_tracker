rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shared workspace pointer — any authenticated user can read/write
    match /config/workspace {
      allow read, write: if request.auth != null;
    }

    // All user data lives under the primary user's uid (the workspace id).
    // Any authenticated user may access it — this is a private family app
    // with only trusted users (James + Whitney) able to sign in.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
